# OVH API credentials
# Create at: https://api.ovh.com/createToken
OVH_ENDPOINT="ovh-eu"
OVH_APPLICATION_KEY=""
OVH_APPLICATION_SECRET=""
OVH_CONSUMER_KEY=""

# Tailscale OAuth credentials
# Create at: https://login.tailscale.com/admin/settings/oauth
# Scopes: auth_keys + devices:read (recommended) — see docs/adr/0008
TAILSCALE_OAUTH_CLIENT_ID=""
TAILSCALE_OAUTH_CLIENT_SECRET=""

# S3 backend credentials (optional, only if using remote state)
# See README.md "Remote State" section
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
