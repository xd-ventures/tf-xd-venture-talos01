# OVH Object Storage Backend Configuration (DEPRECATED)
#
# RECOMMENDATION: Use environment variables instead of this file.
# See ADR-0010 for the recommended approach.
#
# Environment variables (preferred):
#   export AWS_ACCESS_KEY_ID="<ovh-s3-access-key>"
#   export AWS_SECRET_ACCESS_KEY="<ovh-s3-secret-key>"
#
# With environment variables, you can simply run:
#   tofu init -migrate-state
#
# If you must use this file:
# 1. Copy to backend.tfvars (NEVER commit - it's in .gitignore)
# 2. Fill in credentials below
# 3. Run: tofu init -backend-config=backend.tfvars -migrate-state
#
# NOTE: This file is kept for backwards compatibility but environment
# variables are the recommended approach for credential management.

# These values match the defaults in backend.tf, only override if needed
# endpoint = "https://s3.gra.io.cloud.ovh.net"
# bucket   = "xd-venture-terraform-state"
# region   = "gra"

# S3 credentials from OVH (DO NOT COMMIT these values!)
# Prefer environment variables over this file.
access_key = ""
secret_key = ""
