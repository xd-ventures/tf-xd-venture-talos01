# Backend Configuration for S3-Compatible Object Storage
#
# Copy this file and fill in your values:
#   cp backend.tfvars.example backend.tfvars
#
# Then initialize:
#   tofu init -backend-config=backend.tfvars
#
# backend.tfvars is gitignored and will never be committed.
# See ADR-0006 and ADR-0010 for details.

# Bucket name (create in your provider's control panel first)
bucket = ""

# Region
region = "gra"

# S3-compatible endpoint
# OVH Object Storage regions:
#   GRA (Gravelines, France):   https://s3.gra.io.cloud.ovh.net
#   SBG (Strasbourg, France):   https://s3.sbg.io.cloud.ovh.net
#   DE  (Frankfurt, Germany):   https://s3.de.io.cloud.ovh.net
#   UK  (London, UK):           https://s3.uk.io.cloud.ovh.net
#   BHS (Beauharnois, Canada):  https://s3.bhs.io.cloud.ovh.net
#   WAW (Warsaw, Poland):       https://s3.waw.io.cloud.ovh.net
#
# For AWS S3, omit this block entirely (uses default endpoint).
# For MinIO: http://minio.example.com:9000
endpoints = {
  s3 = "https://s3.gra.io.cloud.ovh.net"
}

# Credentials: set via environment variables (NEVER put secrets here)
#   export AWS_ACCESS_KEY_ID="<your-access-key>"
#   export AWS_SECRET_ACCESS_KEY="<your-secret-key>"
