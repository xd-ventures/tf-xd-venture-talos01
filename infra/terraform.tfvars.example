# OVH Configuration
ovh_endpoint   = "ovh-eu"  # Change to your OVH endpoint (ovh-eu, ovh-ca, ovh-us, etc.)
ovh_subsidiary = "FR"      # OVH subsidiary where server was ordered (FR, DE, ES, GB, CA, US, etc.)

# Server Management
monitoring_enabled = false # OVH monitoring; keep disabled — Talos does not respond to OVH's probes
server_state       = "ok"  # Server state (ok, disabled, etc.)

# Talos OS Configuration
talos_version    = "v1.12.0"                       # Talos OS version to deploy
# upgrade_mode   = "reinstall"                     # "upgrade" = in-place talosctl upgrades (ADR-0013 Phase 2); flipping cascades ONE reinstall — see runbook
# kubernetes_version = "1.35.0"                    # Must match talos_version's support matrix (see variables.tf)
cluster_name     = "talos-xd-venture"              # Kubernetes cluster name
cluster_endpoint = "https://<server-ip>:6443"      # Replace <server-ip> with actual server IP (used when Tailscale not configured)
talos_extensions = []                              # Image factory extensions, full names (e.g., ["siderolabs/qemu-guest-agent", "siderolabs/iscsi-tools"])
use_raw_image    = false                           # Use raw (.raw.xz) format if true, qcow2 if false (default: false, qcow2 recommended)

# Tailscale Configuration (optional - enables secure access via Tailscale only)
# When configured, the cluster will:
# - Include the Tailscale extension in the image
# - Use ts.net hostname as the cluster endpoint
#
# Authentication: Use OAuth client (recommended) - see ADR-0008
# Set via environment variables:
#   TAILSCALE_OAUTH_CLIENT_ID="..."
#   TAILSCALE_OAUTH_CLIENT_SECRET="..."
#
# Setup OAuth client at: Tailscale Admin -> Settings -> OAuth clients
# Recommended scopes: auth_keys + devices:read + devices:core (see ADR-0008)
#   devices:core enables automatic stale-device cleanup on reinstall (issue #156);
#   without it, the first reinstall with a stale device fails with a 403
# Required ACL: {"tagOwners": {"tag:k8s-cluster": ["tag:terraform"]}}
#
tailscale_hostname      = "talos-xd-venture"     # Hostname for the Tailscale node (without .ts.net suffix)
tailscale_tailnet       = "tail12345"            # Tailnet name (find in Tailscale admin console, part after hostname in *.ts.net)
tailscale_tags          = ["tag:k8s-cluster"]    # Tags for the device (must be owned by OAuth client)
# tailscale_device_lookup = true                  # Auto-discover IP via Tailscale API (default: true, requires 'devices:read' scope)
# tailscale_ip          = ""                     # Manual IP override (only needed if device_lookup=false — not validated by maintainers)
# tailscale_extra_args  = []                     # Extra args (e.g., ["TS_ACCEPT_ROUTES=true", "TS_ADVERTISE_EXIT_NODE=true"])

# Firewall Configuration (blocks public IP access, allows only Tailscale)
# =========================================================================
# WARNING: Only enable after verifying Tailscale connectivity works!
#
# Verification steps:
#   1. Deploy with enable_firewall = false
#   2. Verify Tailscale access works: run kubectl/talosctl against the
#      ts.net endpoint (see "4. Access the Cluster" in README.md)
#   3. Set enable_firewall = true and run: tofu apply (triggers a reinstall —
#      the firewall is baked into the config drive, active from first boot)
#   4. Run: tofu output firewall_verification_commands
#      Execute each command: public-IP checks should FAIL, Tailscale should SUCCEED
#   5. Summary at any time: tofu output firewall_status
#
# If locked out: Use OVH iKVM console access to recover
#
enable_firewall = false  # Set to true ONLY after verifying Tailscale access works

# Advanced firewall settings (defaults work for most setups)
# pod_network_cidr    = "10.244.0.0/16"       # Cilium pod CIDR (Kubernetes IPAM)
# tailscale_ipv4_cidr = "100.64.0.0/10"       # Tailscale IPv4 range
# tailscale_ipv6_cidr = "fd7a:115c:a1e0::/48" # Tailscale IPv6 range

# ArgoCD GitOps (optional - deploys ArgoCD via Helm after bootstrap)
# ==========================================================================
# Enable only after the cluster is bootstrapped and reachable.
# Hardening flow after first login (see SECURITY.md "Known Security
# Considerations"): change the admin password, delete the
# argocd-initial-admin-secret, then set argocd_disable_admin = true here
# and re-apply.
#
# argocd_enabled          = true
# argocd_server_insecure  = true    # No TLS on the server; safe via Tailscale + port-forward
# argocd_disable_admin    = false   # Set true after password rotation + SSO/extra accounts
# argocd_deploy_guestbook = false   # Demo app to exercise the GitOps workflow
# argocd_chart_version    = "9.7.1" # Pinned default; managed by Renovate

# Shodan Network Monitoring (optional - alerts on accidental public exposure)
# ==========================================================================
# Monitors the server's public IP via Shodan and alerts when services are
# exposed. Useful for verifying firewall effectiveness.
#
# Requirements:
#   - Shodan account (free tier supports up to 16 IPs)
#   - API key from https://account.shodan.io/
#   - Set TF_VAR_shodan_api_key in .env (loaded via direnv)
#
# shodan_enabled = true
# shodan_triggers = ["new_service", "vulnerable", "open_database", "ssl_expired", "internet_scanner", "iot"]
# shodan_notifiers = ["default"]  # "default" = email configured in Shodan account

# ZFS Pool Configuration (optional - automates ZFS mirror pool creation)
# ==========================================================================
# Creates a ZFS mirror pool via an inline manifest Job during bootstrap.
# The Job is idempotent — safe to re-apply on existing pools.
# See ADR-0004 for storage strategy documentation.
#
# zfs_pool_enabled    = true
# zfs_pool_name       = "tank"
# zfs_pool_mount_point = "/var/mnt/data"
# zfs_pool_disks = [
#   { device = "/dev/nvme0n1", partition = 3 },  # Third partition on OS disk
#   { device = "/dev/nvme1n1", partition = 1 },  # First partition on data disk
# ]

# -----------------------------------------------------------------------------
# etcd backups (talos-backup — ADR-0018, #316)
# -----------------------------------------------------------------------------
# talos_backup_enabled        = true
# talos_backup_age_public_key = "age1..." # public key only; PRIVATE key custody per ADR-0018 decision 4
# talos_backup_s3_bucket      = "my-cluster-etcd-backups"
# talos_backup_s3_region      = "gra"
# ovh_cloud_project_id        = "<public-cloud-project-id>" # identifier — keep out of Git (#300)
